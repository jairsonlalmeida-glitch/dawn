<style>
.custom-hero-heading {
  color: #ffffff;
  font-size: 48px;
}
</style>

<section class="hero">
  {% if section.settings.video_url != blank %}
    <video autoplay muted loop playsinline class="hero-video">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | img_url: '1920x' }}" alt="{{ section.settings.heading }}">
      {% endif %}
    </video>
  {% elsif section.settings.hero_image != blank %}
    <img src="{{ section.settings.hero_image | img_url: '1920x' }}" alt="{{ section.settings.heading }}" class="hero-video">
  {% else %}
    <div class="hero-video" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);"></div>
  {% endif %}

  <div class="hero-content">
    {% if section.settings.heading != blank %}
      <h1 class="custom-hero-heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
    <div class="cta-buttons">
      {% if section.settings.cta_primary_label != blank %}
        <a href="{{ section.settings.cta_primary_url }}" class="btn primary">{{ section.settings.cta_primary_label }}</a>
      {% endif %}
      {% if section.settings.cta_secondary_label != blank %}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn secondary">{{ section.settings.cta_secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "header",
      "content": "Video & Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (mp4)",
      "info": "Upload your video to Files and paste the URL here."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Fallback / Hero image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Own the Summer"
     
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium swimwear inspired by Cabo Verde confidence."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop New Drop"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "Explore Best Sellers"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}