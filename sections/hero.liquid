{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your Headline"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Your subheadline or description."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Hero Video URL (MP4)",
      "default": ""
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

<section class="hero">
  {% if section.settings.video_url != blank %}
    <video class="hero-video" autoplay loop muted playsinline>
      <source src="{{ section.settings.video_url }}" type="video/mp4">
      {% if section.settings.fallback_image != blank %}
        <img src="{{ section.settings.fallback_image | img_url: 'master' }}" alt="Hero image" />
      {% endif %}
    </video>
  {% elsif section.settings.fallback_image != blank %}
    <img class="hero-video" src="{{ section.settings.fallback_image | img_url: 'master' }}" alt="Hero image" />
  {% endif %}
  <div class="hero-content">
    <h2>{{ section.settings.headline }}</h2>
    <p>{{ section.settings.subheadline }}</p>
    {% if section.settings.button_link != blank and section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="btn primary">{{ section.settings.button_text }}</a>
    {% endif %}
  </div>
</section>
