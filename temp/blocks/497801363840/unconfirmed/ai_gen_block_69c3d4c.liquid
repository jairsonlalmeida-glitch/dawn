{% doc %}
  @prompt
    Create a horizontal auto-scrolling image carousel for the product page that automatically pulls and displays the product's existing images. The carousel should scroll laterally with manual swipe/arrow navigation and automatic sliding every 3-4 seconds. Include dot indicators at the bottom. Hide the default product image gallery so only this carousel is visible. Style should be clean, minimal, and premium — full-width images, smooth transitions, no borders. Designed for a high-end swimwear brand.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-viewport-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
  }

  .ai-carousel-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: {{ block.settings.arrow_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-carousel-arrow-{{ ai_gen_id }}--prev {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}--next {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: {{ block.settings.dots_spacing }}px;
    z-index: 10;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .ai-carousel-dot-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-carousel-empty-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-carousel-empty-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-arrow-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.8);
      height: calc({{ block.settings.arrow_size }}px * 0.8);
    }

    .ai-carousel-arrow-{{ ai_gen_id }}--prev {
      left: calc({{ block.settings.arrow_offset }}px * 0.5);
    }

    .ai-carousel-arrow-{{ ai_gen_id }}--next {
      right: calc({{ block.settings.arrow_offset }}px * 0.5);
    }

    .ai-carousel-dot-{{ ai_gen_id }} {
      width: calc({{ block.settings.dot_size }}px * 0.8);
      height: calc({{ block.settings.dot_size }}px * 0.8);
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }}
  class="ai-carousel-container-{{ ai_gen_id }}"
  data-autoplay-interval="{{ block.settings.autoplay_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-carousel-viewport-{{ ai_gen_id }}">
    {% if product.media.size > 0 %}
      <div class="ai-carousel-track-{{ ai_gen_id }}">
        {% for media in product.media %}
          {% if media.media_type == 'image' %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}">
              <img
                src="{{ media | image_url: width: 2000 }}"
                alt="{{ media.alt | escape }}"
                loading="lazy"
                width="{{ media.width }}"
                height="{{ media.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_arrows %}
        <button
          class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-{{ ai_gen_id }}--prev"
          aria-label="Previous image"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="ai-carousel-arrow-{{ ai_gen_id }} ai-carousel-arrow-{{ ai_gen_id }}--next"
          aria-label="Next image"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_dots %}
        <div class="ai-carousel-dots-{{ ai_gen_id }}">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <button
                class="ai-carousel-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                aria-label="Go to image {{ forloop.index }}"
                data-index="{{ forloop.index0 }}"
              ></button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-carousel-empty-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayTimer = null;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}--next');
        this.autoplayInterval = parseInt(this.dataset.autoplayInterval) * 1000;

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        this.setupTouchEvents();
        this.startAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevious());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      setupTouchEvents() {
        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
          this.stopAutoplay();
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
          this.startAutoplay();
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNext();
          } else {
            this.goToPrevious();
          }
        }
      }

      goToSlide(index) {
        if (this.isTransitioning || index === this.currentIndex) return;

        this.isTransitioning = true;
        this.currentIndex = index;
        this.updateCarousel();

        setTimeout(() => {
          this.isTransitioning = false;
        }, 600);
      }

      goToNext() {
        const nextIndex = (this.currentIndex + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      goToPrevious() {
        const prevIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      updateCarousel() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        if (this.autoplayInterval > 0 && this.slides.length > 1) {
          this.stopAutoplay();
          this.autoplayTimer = setInterval(() => {
            this.goToNext();
          }, this.autoplayInterval);
        }
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product image carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100,
      "info": "100% = square, 75% = landscape, 125% = portrait"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4,
      "info": "Set to 0 to disable autoplay"
    },
    {
      "type": "header",
      "content": "Navigation arrows"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 45
    },
    {
      "type": "range",
      "id": "arrow_offset",
      "label": "Arrow offset from edge",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "arrow_opacity",
      "label": "Arrow opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "header",
      "content": "Dot indicators"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 6,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "dots_spacing",
      "label": "Spacing between dots",
      "min": 4,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "dots_offset",
      "label": "Dots offset from bottom",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "dot_opacity",
      "label": "Inactive dot opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Product image carousel"
    }
  ]
}
{% endschema %}
