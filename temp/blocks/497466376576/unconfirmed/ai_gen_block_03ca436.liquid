{% doc %}
  @prompt
    Create a custom Liquid block for the product page that displays the product's Short Description metafield (custom.short_description). It should render the metafield value as styled text, matching the product page typography. If the metafield is empty, display nothing. The block should be reusable and insertable in the product main section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if product.metafields.custom.short_description != blank %}
  {% style %}
    .ai-product-short-description-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      margin: 0;
      padding: 0;
      font-family: var(--font-body-family);
      font-size: calc(var(--font-body-scale) * 1rem);
      line-height: 1.6;
      color: rgb(var(--color-foreground));
    }

    .ai-product-short-description-{{ ai_gen_id }} p {
      margin: 0 0 1em 0;
    }

    .ai-product-short-description-{{ ai_gen_id }} p:last-child {
      margin-bottom: 0;
    }

    .ai-product-short-description-{{ ai_gen_id }} strong,
    .ai-product-short-description-{{ ai_gen_id }} b {
      font-weight: 600;
    }

    .ai-product-short-description-{{ ai_gen_id }} em,
    .ai-product-short-description-{{ ai_gen_id }} i {
      font-style: italic;
    }

    .ai-product-short-description-{{ ai_gen_id }} a {
      color: rgb(var(--color-foreground));
      text-decoration: underline;
    }

    .ai-product-short-description-{{ ai_gen_id }} a:hover {
      opacity: 0.8;
    }
  {% endstyle %}

  <div class="ai-product-short-description-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    {{ product.metafields.custom.short_description }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Product short description",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays the product's short description metafield (custom.short_description). If the metafield is empty, nothing will be shown."
    }
  ],
  "presets": [
    {
      "name": "Product short description"
    }
  ]
}
{% endschema %}
